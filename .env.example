# Copy to .env and fill in real values. Never commit the real .env file.

# API
BASE_API_URL=http://localhost:1337
STUDENT_GROUP=Group1

# Webhook auth - random long string, e.g. `openssl rand -hex 32`
WEBHOOK_SECRET=

# AES-256 payload encryption key - Base64-encoded 32-byte (256-bit) key, e.g. `openssl rand -base64 32`
APP_ENCRYPTION_KEY=

# Messaging provider credentials
SWIFT_SEND_API_KEY=
ASYNC_FLOW_API_KEY=
SECURE_POST_CLIENT_ID=
SECURE_POST_CLIENT_SECRET=
LEGACY_LINK_USERNAME=
LEGACY_LINK_PASSWORD=

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=restservice_db
POSTGRES_USER=
POSTGRES_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=
RABBITMQ_PASSWORD=
RABBITMQ_LISTENER_AUTO_STARTUP=true

# Data retention (GDPR) - optional, defaults shown
RETENTION_CLEANUP_CRON=0 0 2 * * *
RETENTION_IDENTIFIABLE_DATA_DAYS=14
RETENTION_META_INFORMATION_DAYS=365
