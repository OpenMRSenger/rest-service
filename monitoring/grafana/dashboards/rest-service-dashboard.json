{
  "uid": "rest-service",
  "title": "Rest Service - Overview",
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Instance Up",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "up{job=\"openmrsenger\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "datasource": "prometheus"
    },
    {
      "type": "graph",
      "title": "JVM Memory Used",
      "gridPos": { "x": 6, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "datasource": "prometheus"
    },
    {
      "type": "graph",
      "title": "HTTP Request Rate (5m)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count[5m])",
          "legendFormat": "{{uri}} {{method}}",
          "refId": "A"
        }
      ],
      "datasource": "prometheus"
    },
    {
      "type": "graph",
      "title": "Database Connections",
      "gridPos": { "x": 12, "y": 4, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "datasource_connections_active{pool=~\".*\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "datasource": "prometheus"
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] }
}
